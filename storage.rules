rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Rules for user profile images
    match /profile-images/{userId} {
      // Any authenticated user can read profile images (e.g., to see other user's profiles)
      allow read: if request.auth != null;
      
      // Only the authenticated user whose UID matches the file's name can write (create, update, delete).
      // We also check that the uploaded file is an image and is smaller than 5MB.
      allow write: if request.auth != null && 
                    request.auth.uid == userId &&
                    request.resource.size < 5 * 1024 * 1024 &&
                    request.resource.contentType.matches('image/.*');
    }
  }
}
