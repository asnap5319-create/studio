rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow write access to any authenticated user for their own profile image.
    // The app logic ensures they only write to their own path.
    match /profile-images/{userId} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
