rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Rules for user profile images
    match /profile-images/{userId} {
      // Any authenticated user can read profile images (e.g., to see other user's profiles)
      allow read: if request.auth != null;
      
      // Allow write if user is authenticated, and file is a small image.
      // Temporarily removed owner check (request.auth.uid == userId) for debugging.
      allow write: if request.auth != null &&
                    request.resource.size < 5 * 1024 * 1024 &&
                    request.resource.contentType.matches('image/.*');
    }
  }
}
