rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // 👑 मास्टर एडमिन फंक्शन - जो ईमेल आपने दिया है उसे "God Mode" देना
    // ------------------------------------------------------------------------
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.email.lower() == "asnap5319@gmail.com".lower());
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ------------------------------------------------------------------------
    // ⚔️ GLOBAL OVERRIDE (एडमिन के लिए सब कुछ खुला)
    // ------------------------------------------------------------------------
    match /{path=**} {
      allow read, write: if isAdmin();
      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------------
    // यूजर्स और उनके कंटेंट के नियम
    // ------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isOwner(userId);

      match /posts/{postId} { 
        allow read: if true;
        allow create: if isOwner(userId);
        allow update: if isAdmin() || isOwner(userId) || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'likeCount', 'commentCount']));
        allow delete: if isAdmin() || isOwner(userId);

        match /{allSubcollections=**} {
          allow read, write: if isAdmin() || isOwner(userId);
        }
      }

      match /stories/{storyId} { 
        allow read: if true;
        allow write: if isAdmin() || isOwner(userId);
      }
      
      match /notifications/{notificationId} {
        allow read, update, delete: if isAdmin() || isOwner(userId);
        allow create: if isSignedIn();
      }
    }

    // ------------------------------------------------------------------------
    // चैट्स और मेसेजेस के नियम
    // ------------------------------------------------------------------------
    match /chats/{chatId} {
      allow read, update, delete: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.participants);
      allow create: if isSignedIn();

      match /messages/{messageId} {
        allow read: if isAdmin() || (isSignedIn());
        allow create: if isSignedIn();
        allow delete: if isAdmin();
      }
    }

    match /user_followers/{followedUserId}/followers/{followerUserId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == followerUserId);
    }

    match /user_following/{followerUserId}/following/{followedUserId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == followerUserId);
    }
  }
}