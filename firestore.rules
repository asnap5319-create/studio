/**
 * This ruleset enforces a strict user-ownership model for a social media application.
 * Users have full control over their own profiles, posts, and stories, but cannot
 * modify sensitive, system-managed data like earnings or view counts.
 *
 * Core Philosophy:
 * The security model is centered on user ownership. A user's identity (request.auth.uid)
 * is the primary gatekeeper for all create, update, and delete operations on their own data.
 * Public content is generally readable by any authenticated user, but user enumeration is disabled.
 *
 * Data Structure:
 * The data is organized hierarchically, with nearly all user-generated content nested under
 * the /users/{userId} path (e.g., /users/{userId}/posts/{postId}). This structure makes
 * ownership-based security rules simple, performant, and easy to understand.
 *
 * Key Security Decisions:
 * - User Enumeration Disabled: The top-level `/users` collection cannot be listed, preventing
 *   malicious actors from scraping all user profiles.
 * - Client-Side Earnings Blocked: Fields like `totalEarnings`, `postEarnings`, and `viewCount`
 *   are immutable for the client. The rules assume a trusted backend service (e.g., Cloud Functions)
 *   is responsible for calculating and updating these values, preventing users from faking their own earnings.
 * - Private Data Segregation: Sensitive financial data is stored in a separate, owner-only
 *   document (/users/{userId}/earnings/data), ensuring it is never accidentally exposed with public
 *   profile data.
 * - Denormalization for Authorization: The rules are designed to work with a denormalized data
 *   model where ownership information is copied to child documents. This avoids slow and costly `get()`
 *   calls within the rules themselves, leading to better performance and scalability.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to abstract and simplify rule logic.

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     * This is the foundation of the ownership model.
     * @param userId The UID to check against the authenticated user.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * A robust check for update/delete operations, ensuring the user is the owner
     * AND the document they are trying to modify actually exists.
     * @param userId The UID of the document's owner.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Validates required fields for a new user profile upon creation.
     * Enforces that the document ID matches the user's auth UID and that
     * the system-managed `totalEarnings` field starts at zero.
     */
    function isValidUserProfileCreate(userId) {
      let data = request.resource.data;
      return isOwner(userId)
        && data.id == userId
        && data.totalEarnings == 0;
    }

    /**
     * Validates a user profile update.
     * Enforces immutability for critical fields: the user ID, creation timestamp,
     * and the server-controlled `totalEarnings`.
     */
    function canUpdateProfile() {
      let data = request.resource.data;
      let existingData = resource.data;
      return data.id == existingData.id
        && data.createdAt == existingData.createdAt
        && data.totalEarnings == existingData.totalEarnings;
    }

    /**
     * Validates a new post upon creation.
     * Ensures the post's internal `userId` matches the creator's auth UID and
     * that system-managed fields `viewCount` and `postEarnings` start at zero.
     */
    function isValidPostCreate(ownerId) {
      let data = request.resource.data;
      return isOwner(ownerId)
        && data.userId == ownerId
        && data.viewCount == 0
        && data.postEarnings == 0;
    }

    /**
     * Validates a post update.
     * Enforces immutability for critical fields: owner ID, creation timestamp,
     * and server-controlled `viewCount` and `postEarnings`.
     */
    function canUpdatePost() {
      let data = request.resource.data;
      let existingData = resource.data;
      return data.userId == existingData.userId
        && data.createdAt == existingData.createdAt
        && data.viewCount == existingData.viewCount
        && data.postEarnings == existingData.postEarnings;
    }

    /**
     * Validates a new story upon creation.
     * Ensures the story's internal `userId` matches the creator's auth UID.
     */
    function isValidStoryCreate(ownerId) {
      return isOwner(ownerId) && request.resource.data.userId == ownerId;
    }

    /**
     * Validates a story update.
     * Enforces immutability for owner ID and creation timestamp.
     */
    function canUpdateStory() {
      let data = request.resource.data;
      let existingData = resource.data;
      return data.userId == existingData.userId
        && data.createdAt == existingData.createdAt;
    }

    /**
     * Validates a new comment upon creation.
     * Ensures the commenter is signed in and that the comment's internal `userId`
     * and `postId` match the authenticated user and the parent post's ID.
     */
    function isValidCommentCreate(postId) {
      let data = request.resource.data;
      return isSignedIn()
        && data.userId == request.auth.uid
        && data.postId == postId;
    }

    /**
     * Validates a new like upon creation.
     * The `likerId` in the path acts as a primary key, so this rule ensures
     * the user can only create a 'like' document with their own UID. Also validates
     * relational integrity with internal `userId` and `postId` fields.
     */
    function isValidLikeCreate(likerId, postId) {
      let data = request.resource.data;
      return isOwner(likerId)
        && data.userId == likerId
        && data.postId == postId;
    }


    /**
     * @description Manages user profile documents. Allows users to create and manage their
     *              own profile, which is readable by any authenticated user. Disallows listing
     *              to prevent user enumeration.
     * @path /users/{userId}
     * @allow (create) An authenticated user can create their own user profile document.
     * @deny  (list) A client cannot request a list of all users.
     * @principle Enforces self-creation and ownership, while preventing data scraping.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isValidUserProfileCreate(userId);
      allow update: if isExistingOwner(userId) && canUpdateProfile();
      allow delete: if isExistingOwner(userId);

      /**
       * @description Secures a user's private earnings data. Only the user themselves can
       *              read this data. All write operations are disabled from the client-side
       *              to ensure earnings can only be updated by a trusted backend service.
       * @path /users/{userId}/earnings/data
       * @allow (get) An authenticated user can read their own earnings document.
       * @deny  (create) A user cannot create or modify their own earnings data.
       * @principle Segregates sensitive data and restricts writes to trusted server environments.
       */
      match /earnings/data {
        allow get: if isOwner(userId);
        allow list: if false; // This is a single document, list is not applicable but explicitly denied.
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }

      /**
       * @description Manages the list of users who follow a given user.
       * @path /users/{userId}/followers/{followerId}
       * @allow (create) A user can add themselves to another user's followers list.
       * @deny  (update) The relationship document cannot be modified once created.
       * @principle Allows users to control their own 'follow' actions.
       */
      match /followers/{followerId} {
        allow get: if isSignedIn();
        allow list: if isOwner(userId);
        allow create: if isOwner(followerId);
        allow update: if false;
        allow delete: if isOwner(followerId);
      }

      /**
       * @description Manages the list of users that a given user is following.
       * @path /users/{userId}/following/{followedUserId}
       * @allow (create) A user can create a document to follow another user.
       * @deny  (update) The relationship document cannot be modified once created.
       * @principle Allows users to control their own 'following' list.
       */
      match /following/{followedUserId} {
        allow get: if isSignedIn();
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if false;
        allow delete: if isOwner(userId);
      }

      /**
       * @description Secures user-created posts. Posts are publicly readable by any signed-in user,
       *              but only the original author can create, update, or delete them.
       *              Server-managed fields like `viewCount` and `postEarnings` are immutable.
       * @path /users/{userId}/posts/{postId}
       * @allow (get) Any authenticated user can read a post.
       * @deny  (update) A user tries to update another user's post.
       * @principle Enforces a "Public Read, Owner-Only Write" access control pattern.
       */
      match /posts/{postId} {
        allow get, list: if isSignedIn();
        allow create: if isValidPostCreate(userId); // Fixed: ownerId -> userId
        allow update: if isExistingOwner(userId) && canUpdatePost(); // Fixed: ownerId -> userId
        allow delete: if isExistingOwner(userId); // Fixed: ownerId -> userId

        /**
         * @description Secures comments on a post. Any signed-in user can read or create a comment.
         *              Only the comment's creator or the owner of the parent post can delete it.
         * @path /users/{userId}/posts/{postId}/comments/{commentId}
         * @allow (delete) The owner of the post can delete any comment on their post.
         * @deny  (delete) A random user cannot delete someone else's comment.
         * @principle Allows for community moderation by the content owner.
         */
        match /comments/{commentId} {
          allow get, list: if isSignedIn();
          allow create: if isValidCommentCreate(postId);
          allow update: if isExistingOwner(resource.data.userId);
          allow delete: if resource != null && (isOwner(resource.data.userId) || isOwner(userId)); // Fixed: postOwnerId -> userId
        }

        /**
         * @description Secures likes on a post. The document ID (`likerId`) prevents a user
         *              from liking a post more than once. Users can only create or delete their own like.
         * @path /users/{userId}/posts/{postId}/likes/{likerId}
         * @allow (create) A user can like a post, creating a document with their UID as the ID.
         * @deny  (create) A user cannot create a 'like' on behalf of another user.
         * @principle Enforces document ownership where the document ID itself is the owner's UID.
         */
        match /likes/{likerId} {
          allow get, list: if isSignedIn();
          allow create: if isValidLikeCreate(likerId, postId);
          allow update: if false;
          allow delete: if isExistingOwner(likerId);
        }
      }

      /**
       * @description Secures user-created stories. Stories are readable by any signed-in user,
       *              but only the original author can create, update, or delete them.
       * @path /users/{userId}/stories/{storyId}
       * @allow (get) Any authenticated user can read a story.
       * @deny  (create) A user tries to create a story under another user's ID.
       * @principle Enforces a "Public Read, Owner-Only Write" access control pattern.
       */
      match /stories/{storyId} {
        allow get, list: if isSignedIn();
        allow create: if isValidStoryCreate(userId); // Fixed: ownerId -> userId
        allow update: if isExistingOwner(userId) && canUpdateStory(); // Fixed: ownerId -> userId
        allow delete: if isExistingOwner(userId); // Fixed: ownerId -> userId
      }
    }
  }
}