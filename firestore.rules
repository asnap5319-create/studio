
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 👑 MASTER ADMIN: Absolute Priority
    // This allows asnap5319@gmail.com to do ANYTHING on ANY collection.
    function isMasterAdmin() {
      return request.auth != null && 
             request.auth.token.email != null &&
             request.auth.token.email.lower() == "asnap5319@gmail.com".lower();
    }

    // This rule allows the Master Admin to bypass ALL other rules for ALL paths.
    // It must be the very first match to take precedence.
    match /{allPaths=**} {
      allow read, write, delete: if isMasterAdmin();
    }

    // 🛡️ GENERAL USER RULES (Standard users follow these)
    
    // Global rule for collection group 'posts' to ensure feed works
    match /{path=**}/posts/{postId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid == userId || isMasterAdmin());
      allow delete: if request.auth != null && (request.auth.uid == userId || isMasterAdmin());

      match /posts/{postId} {
        allow read: if true;
        allow create: if request.auth != null && (request.auth.uid == userId || isMasterAdmin());
        allow update: if request.auth != null && (request.auth.uid == userId || isMasterAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'likeCount', 'commentCount']));
        allow delete: if request.auth != null && (request.auth.uid == userId || isMasterAdmin());
        
        match /likes/{likeId} {
          allow read: if true;
          allow write: if request.auth != null;
        }
        
        match /comments/{commentId} {
          allow read: if true;
          allow write: if request.auth != null;
          
          match /likes/{commentLikeId} {
            allow read: if true;
            allow write: if request.auth != null;
          }
        }
      }
      
      match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null && (request.auth.uid == userId || isMasterAdmin());
        allow create: if request.auth != null;
      }
    }

    match /chats/{chatId} {
      allow read, update, delete: if request.auth != null && (request.auth.uid in resource.data.participants || isMasterAdmin());
      allow create: if request.auth != null;

      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (request.auth.uid == resource.data.senderId || isMasterAdmin()); 
      }
    }

    match /user_followers/{followedUserId}/followers/{followerUserId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == followerUserId || isMasterAdmin());
    }

    match /user_following/{followerUserId}/following/{followedUserId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == followerUserId || isMasterAdmin());
    }
  }
}
