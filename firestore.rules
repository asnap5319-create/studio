rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
      
      match /posts/{postId} {
        allow read: if true;
        allow write: if isAuthenticated();
        
        match /likes/{likeId} {
          allow read: if true;
          allow write: if isAuthenticated();
        }
        
        match /comments/{commentId} {
          allow read: if true;
          allow write: if isAuthenticated();
          
          match /likes/{likeId} {
            allow read: if true;
            allow write: if isAuthenticated();
          }
        }
      }
      
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if isAuthenticated();
        allow update, delete: if isOwner(userId);
      }
    }

    // Global collection group access for the feed
    match /{path=**}/posts/{postId} {
      allow read: if true;
    }

    // Chat system rules
    match /chats/{chatId} {
      allow read, write, create: if isAuthenticated();
      
      match /messages/{messageId} {
        allow read, create, delete: if isAuthenticated();
      }
    }

    // Follow system rules
    match /user_followers/{followedUserId}/followers/{followerUserId} {
      allow read: if true;
      allow write: if isOwner(followerUserId);
    }
    match /user_following/{followerUserId}/following/{followedUserId} {
      allow read: if true;
      allow write: if isOwner(followerUserId);
    }

    // Catch-all for other collections
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}