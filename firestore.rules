/**
 * Core Philosophy: This ruleset enforces a social media security model centered on user ownership and public readability for authenticated users.
 * User profiles are public, but user-generated content like posts and stories are visible to any signed-in user, fostering a "global feed" or "discover" experience.
 * This model prioritizes performant, secure queries by ensuring read rules are not overly complex while maintaining strict ownership for all write operations.
 *
 * Data Structure:
 * - /users/{userId}: Core user profile data.
 * - /users/{userId}/posts/{postId}: Posts owned by a user.
 * - /users/{userId}/stories/{storyId}: Stories owned by a user.
 * - /user_followers/{followedUserId}/followers/{followerUserId}: A denormalized lookup collection to efficiently check follower relationships.
 * - /user_following/{followerUserId}/following/{followedUserId}: A symmetrical collection for querying who a user follows.
 * - /user_feeds/{userId}/...: A private, read-only collection containing a user's personalized content feed, populated by backend processes.
 *
 * Key Security Decisions:
 * - Public Profiles: User profiles in `/users` can be read by anyone, but only modified by the owner. This supports features like user search.
 * - Authenticated-User-Gated Content: Access to posts, stories, comments, and likes is granted to any authenticated user. This supports a global feed.
 * - Strict Ownership for Writes: All write operations (create, update, delete) are strictly limited to the document owner (e.g., post author, commenter, liker). An exception is made for post owners, who can moderate (delete) comments on their own posts.
 * - Read-Only Feeds: The personalized feed collections (`/user_feeds` and `/user_story_feeds`) are client-side read-only to prevent tampering. All writes must be handled by a trusted backend service.
 * - Relational Integrity: On creation, rules validate that ownership fields within documents (e.g., `post.userId`) match the user ID in the path, ensuring data consistency. These fields are immutable on update.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the requesting user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if a document exists. Used to secure update/delete operations.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * Checks if the user is the owner of an existing document.
     */
    function isOwnerOfExistingDoc(userId) {
      return isOwner(userId) && isExistingDoc();
    }

    /**
     * Checks if the requesting user follows the given user ID.
     * This is a highly performant check that reads a single, specific document.
     */
    function isFollower(followedUserId) {
      return isSignedIn() && exists(/databases/$(database)/documents/user_followers/$(followedUserId)/followers/$(request.auth.uid));
    }

    /**
     * Determines if a user can view semi-private content (e.g., posts, stories).
     * Access is granted to the owner or their followers.
     */
    function canViewContent(ownerId) {
      return isOwner(ownerId) || isFollower(ownerId);
    }
    
    // ------------------------------------------------------------------------
    // Collection Group Rules
    // ------------------------------------------------------------------------
    
    /**
     * @description Allows collection group queries on 'posts' for the global feed.
     * @path /{path=**}/posts/{postId}
     * @allow (get, list) Any authenticated user can read any post.
     * @principle This is crucial for the main feed functionality.
     */
    match /{path=**}/posts/{postId} {
      allow get, list: if isSignedIn();
    }

    // ------------------------------------------------------------------------
    // User Profile Rules
    // ------------------------------------------------------------------------

    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     * @allow (get, list) Anyone can read public user profiles.
     * @allow (create, update) A user can create or update their own profile.
     * @deny (create) A user cannot create a profile for someone else.
     * @principle Public read with owner-only writes. Validates that a user's document `id` matches their auth `uid` on creation.
     */
    match /users/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwnerOfExistingDoc(userId);
      allow delete: if isOwnerOfExistingDoc(userId);

      // ------------------------------------------------------------------------
      // Post & Subcollection Rules
      // ------------------------------------------------------------------------

      /**
       * @description Manages user posts, which are visible to any signed-in user.
       * @path /users/{userId}/posts/{postId}
       * @allow (get, list) Any authenticated user can read posts to enable a global feed.
       * @allow (create) An authenticated user can create a post for themselves.
       * @deny (update) An authenticated user cannot update a post they do not own.
       * @principle Enforces public read access for signed-in users and strict ownership for all writes.
       */
      match /posts/{postId} { 
        allow get, list: if isSignedIn();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isOwnerOfExistingDoc(resource.data.userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isOwnerOfExistingDoc(resource.data.userId);

        /**
         * @description Manages comments on a specific post.
         * @path /users/{userId}/posts/{postId}/comments/{commentId}
         * @allow (get, list) Anyone who is signed in can see the comments on a post.
         * @allow (create) An authenticated user can create a comment on any post.
         * @allow (delete) A user can delete their own comment, or the post owner can delete any comment on their post.
         * @deny (update) A user who is not the comment author cannot update a comment.
         * @principle Inherits read access from the parent post and allows owner/moderator deletion.
         */
        match /comments/{commentId} {
          allow get, list: if isSignedIn(); 
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.postId == postId;
          allow update: if isOwnerOfExistingDoc(resource.data.userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isExistingDoc() && (isOwner(resource.data.userId) || isOwner(userId)); // resource.data.userId is comment owner, userId is post owner
        }

        /**
         * @description Manages likes on a specific post.
         * @path /users/{userId}/posts/{postId}/likes/{likeId}
         * @allow (get, list) Anyone who is signed in can see the likes on a post.
         * @allow (create, delete) An authenticated user can like/unlike any post.
         * @deny (update) Likes are not updatable.
         * @principle Enforces strict ownership for creating/deleting the like.
         */
        match /likes/{likeId} {
          allow get, list: if isSignedIn();
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.postId == postId;
          allow update: if false;
          allow delete: if isOwnerOfExistingDoc(resource.data.userId);
        }
      }

      // ------------------------------------------------------------------------
      // Story Rules
      // ------------------------------------------------------------------------

      /**
       * @description Manages user stories, which are visible to any signed-in user.
       * @path /users/{userId}/stories/{storyId}
       * @allow (get, list) Any authenticated user can read stories.
       * @allow (create) An authenticated user can create a story for themselves.
       * @deny (delete) A user cannot delete a story they do not own.
       * @principle Enforces public read access and strict ownership for all writes.
       */
      match /stories/{storyId} { 
        allow get, list: if isSignedIn();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isOwnerOfExistingDoc(resource.data.userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isOwnerOfExistingDoc(resource.data.userId);
      }
    }

    // ------------------------------------------------------------------------
    // Follow Relationship Rules
    // ------------------------------------------------------------------------

    /**
     * @description Manages the "followers" lookup table. This allows for efficient `exists()` checks.
     * @path /user_followers/{followedUserId}/followers/{followerUserId}
     * @allow (create, delete) A user can add/remove themselves as a follower of another user.
     * @allow (get, list) Any signed-in user can see who follows whom.
     * @deny (create) A user cannot make someone else follow another person.
     * @principle The user initiating the follow (`followerUserId`) owns the relationship document.
     */
    match /user_followers/{followedUserId}/followers/{followerUserId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(followerUserId);
      allow update: if false;
      allow delete: if isOwnerOfExistingDoc(followerUserId);
    }

    /**
     * @description Manages the "following" lookup table. This allows a user to query who they follow.
     * @path /user_following/{followerUserId}/following/{followedUserId}
     * @allow (create, delete) A user can add/remove another user from their "following" list.
     * @allow (get, list) Any signed-in user can see who a user is following.
     * @deny (create) A user cannot modify another user's "following" list.
     * @principle The user initiating the follow (`followerUserId`) owns the relationship document.
     */
    match /user_following/{followerUserId}/following/{followedUserId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(followerUserId);
      allow update: if false;
      allow delete: if isOwnerOfExistingDoc(followerUserId);
    }

    // ------------------------------------------------------------------------
    // Denormalized Feed Rules (Read-Only)
    // ------------------------------------------------------------------------

    /**
     * @description A denormalized, private feed of posts for a user. Populated by a backend process.
     * @path /user_feeds/{feedViewerId}/feed_posts/{feedPostId}
     * @allow (get, list) A user can only read their own post feed.
     * @deny (create, update, delete) All write operations are forbidden from the client.
     * @principle Restricts access to a user's own data tree, enforcing a private, read-only data view.
     */
    match /user_feeds/{feedViewerId}/feed_posts/{feedPostId} {
      allow get, list: if isOwner(feedViewerId);
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description A denormalized, private feed of stories for a user. Populated by a backend process.
     * @path /user_story_feeds/{storyFeedViewerId}/feed_stories/{feedStoryId}
     * @allow (get, list) A user can only read their own story feed.
     * @deny (create, update, delete) All write operations are forbidden from the client.
     * @principle Restricts access to a user's own data tree, enforcing a private, read-only data view.
     */
    match /user_story_feeds/{storyFeedViewerId}/feed_stories/{feedStoryId} {
      allow get, list: if isOwner(storyFeedViewerId);
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
