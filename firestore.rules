rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingDoc() {
      return resource != null;
    }
    
    // ------------------------------------------------------------------------
    // User Profile & Content Rules
    // ------------------------------------------------------------------------
    match /users/{userId} {
      // Profiles are public to read
      allow read: if true;
      
      // Only owner can edit their own profile
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      // Posts subcollection
      match /posts/{postId} { 
        // Posts are public to read
        allow read: if true;
        
        // Only owner can create
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        
        // Allow owner to update OR allow any signed-in user to increment viewCount
        allow update: if isOwner(userId) || 
                       (isSignedIn() && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']));
        
        // Only owner can delete
        allow delete: if isOwner(userId);

        // Comments and Likes
        match /comments/{commentId} {
          allow read: if true;
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
          allow update: if isOwner(resource.data.userId);
          allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isOwner(userId));
        }

        match /likes/{likeId} {
          allow read: if true;
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
          allow delete: if isOwner(resource.data.userId);
        }
      }

      match /stories/{storyId} { 
        allow read: if true;
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isOwner(userId);
      }
      
      match /notifications/{notificationId} {
        // Only recipient can read/manage their notifications
        allow read, update, delete: if isOwner(userId);
        // Any signed-in user can trigger a notification (e.g. following someone)
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      }
    }

    // ------------------------------------------------------------------------
    // Collection Group Matches (Crucial for Global Feed)
    // ------------------------------------------------------------------------
    match /{path=**}/posts/{postId} {
      allow read: if true;
    }
    match /{path=**}/stories/{storyId} {
      allow read: if true;
    }

    // ------------------------------------------------------------------------
    // Follow Relationship Rules
    // ------------------------------------------------------------------------
    match /user_followers/{followedUserId}/followers/{followerUserId} {
      allow read: if true;
      allow write: if request.auth.uid == followerUserId;
    }

    match /user_following/{followerUserId}/following/{followedUserId} {
      allow read: if true;
      allow write: if request.auth.uid == followerUserId;
    }
    
    // ------------------------------------------------------------------------
    // Feed Snapshots (Populated by backend)
    // ------------------------------------------------------------------------
    match /user_feeds/{feedViewerId}/feed_posts/{feedPostId} {
      allow read: if isOwner(feedViewerId);
      allow write: if false;
    }
  }
}