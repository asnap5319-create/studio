rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 👑 MASTER ADMIN: Absolute Control (asnap5319@gmail.com)
    function isMasterAdmin() {
      return request.auth != null && 
             request.auth.token.email != null &&
             request.auth.token.email.lower() == "asnap5319@gmail.com".lower();
    }

    // Allow Master Admin to do everything anywhere
    match /{allPaths=**} {
      allow read, write, delete: if isMasterAdmin();
    }

    // 🛡️ GENERAL RULES
    
    // ALLOW PUBLIC READ FOR POSTS (Important for the feed and links to work)
    match /users/{userId}/posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      match /likes/{likeId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
      
      match /comments/{commentId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;

      match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }

    match /chats/{chatId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;

      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (request.auth.uid == resource.data.senderId || isMasterAdmin()); 
      }
    }

    match /user_followers/{followedUserId}/followers/{followerUserId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == followerUserId || isMasterAdmin());
    }

    match /user_following/{followerUserId}/following/{followedUserId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == followerUserId || isMasterAdmin());
    }
  }
}