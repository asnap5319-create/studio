rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // ------------------------------------------------------------------------
    // User Profile & Content Rules
    // ------------------------------------------------------------------------
    match /users/{userId} {
      // Profiles are public to read
      allow read: if true;
      
      // Only owner can edit their own profile
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      // Posts subcollection
      match /posts/{postId} { 
        // Posts are public to read
        allow read: if true;
        
        // Only owner can create
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        
        // Allow owner to update OR allow any signed-in user to increment viewCount, likeCount, commentCount
        allow update: if isOwner(userId) || 
                       (isSignedIn() && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'likeCount', 'commentCount']));
        
        // Only owner can delete
        allow delete: if isOwner(userId);

        // Comments
        match /comments/{commentId} {
          allow read: if true;
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
          
          // Allow author to update OR allow anyone to increment likeCount
          allow update: if isOwner(resource.data.userId) || 
                         (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount']));
          
          allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isOwner(userId));

          // Likes on comments
          match /likes/{likeId} {
            allow read: if true;
            allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
            allow delete: if isSignedIn() && request.auth.uid == likeId;
          }
        }

        // Likes on posts
        match /likes/{likeId} {
          allow read: if true;
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
          allow delete: if isSignedIn() && request.auth.uid == likeId;
        }
      }

      match /stories/{storyId} { 
        allow read: if true;
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isOwner(userId);
      }
      
      match /notifications/{notificationId} {
        // Only recipient can read/manage their notifications
        allow read, update, delete: if isOwner(userId);
        // Any signed-in user can trigger a notification
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      }
    }

    // ------------------------------------------------------------------------
    // Chat & Messaging Rules
    // ------------------------------------------------------------------------
    match /chats/{chatId} {
      // Allow read/update if user is a participant
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      // Allow create if user is a participant in the new chat
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        // Verify parent chat membership for message access
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        
        // Allow create if user is sender and participant in parent chat
        allow create: if isSignedIn() && 
                      request.resource.data.senderId == request.auth.uid &&
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // ------------------------------------------------------------------------
    // Global Collection Group Matches
    // ------------------------------------------------------------------------
    match /{path=**}/posts/{postId} {
      allow read: if true;
    }
    
    match /{path=**}/stories/{storyId} {
      allow read: if true;
    }

    // ------------------------------------------------------------------------
    // Follow Relationship Rules
    // ------------------------------------------------------------------------
    match /user_followers/{followedUserId}/followers/{followerUserId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == followerUserId;
    }

    match /user_following/{followerUserId}/following/{followedUserId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == followerUserId;
    }
    
    match /user_feeds/{feedViewerId}/feed_posts/{feedPostId} {
      allow read: if isOwner(feedViewerId);
      allow write: if false;
    }
  }
}