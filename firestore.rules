rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 👑 MASTER ADMIN RULE
    function isMasterAdmin() {
      return request.auth != null && 
             request.auth.token.email != null &&
             request.auth.token.email.lower() == "asnap5319@gmail.com".lower();
    }

    // Allow Master Admin to do everything
    match /{allPaths=**} {
      allow read, write, delete: if isMasterAdmin();
    }

    // 🛡️ USER PROFILES
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isMasterAdmin());

      // Notifications
      match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }

      // Posts (Nested inside user)
      match /posts/{postId} {
        allow read: if true;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null; // For global likes/views/comments
        allow delete: if request.auth != null && (request.auth.uid == userId || isMasterAdmin());
        
        match /likes/{likeId} {
          allow read: if true;
          allow write: if request.auth != null;
        }
        
        match /comments/{commentId} {
          allow read: if true;
          allow write: if request.auth != null;
          
          match /likes/{likeId} {
             allow read, write: if request.auth != null;
          }
        }
      }
    }

    // 🌎 GLOBAL COLLECTION GROUP READS (Essential for Feed & Search)
    match /{path=**}/posts/{postId} {
      allow read: if true;
    }

    // 💬 CHATS & MESSAGES
    match /chats/{chatId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;
      allow delete: if isMasterAdmin();

      match /messages/{messageId} {
        allow read: if request.auth != null; 
        allow create: if request.auth != null;
        allow delete: if request.auth != null && request.auth.uid == resource.data.senderId; 
      }
    }

    // 🤝 FOLLOW SYSTEM
    match /user_followers/{followedUserId}/followers/{followerUserId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == followerUserId;
    }

    match /user_following/{followerUserId}/following/{followedUserId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == followedUserId || request.auth.uid == followerUserId;
    }
    
    // Global catch-all to prevent crashes while debugging
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}