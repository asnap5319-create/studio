rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Strict Admin Check using the provided email
    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == "asnap5319@gmail.com" || 
              request.auth.token.email == "asnap5319@gmail.com".lower());
    }
    
    // ------------------------------------------------------------------------
    // User Profile & Content Rules
    // ------------------------------------------------------------------------
    match /users/{userId} {
      // Profiles are public to read
      allow read: if true;
      
      // Only owner can create/update. Admin or owner can delete.
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin() || isOwner(userId);

      // Posts subcollection
      match /posts/{postId} { 
        allow read: if true;
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        
        // Admin or owner can update viewCount etc, or owner can do full update
        allow update: if isOwner(userId) || isAdmin() || 
                       (isSignedIn() && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'likeCount', 'commentCount']));
        
        // Admin or owner can delete
        allow delete: if isAdmin() || isOwner(userId);

        match /comments/{commentId} {
          allow read: if true;
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
          allow update: if isOwner(resource.data.userId) || isAdmin() ||
                         (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount']));
          allow delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isOwner(userId) || isAdmin());
        }

        match /likes/{likeId} {
          allow read: if true;
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
          allow delete: if isSignedIn() && (request.auth.uid == likeId || isAdmin());
        }
      }

      match /stories/{storyId} { 
        allow read: if true;
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update, delete: if isOwner(userId) || isAdmin();
      }
      
      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId) || isAdmin();
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      }
    }

    // ------------------------------------------------------------------------
    // Chat & Messaging Rules
    // ------------------------------------------------------------------------
    match /chats/{chatId} {
      allow read, update: if (isSignedIn() && request.auth.uid in resource.data.participants) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if (isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants) || isAdmin();
        allow create: if isSignedIn() && 
                      request.resource.data.senderId == request.auth.uid &&
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow delete: if isAdmin();
      }
    }

    // ------------------------------------------------------------------------
    // Global Collection Group Matches (Crucial for Explore/Admin)
    // ------------------------------------------------------------------------
    match /{path=**}/posts/{postId} {
      allow read: if true;
      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------------
    // Follow Relationship Rules
    // ------------------------------------------------------------------------
    match /user_followers/{followedUserId}/followers/{followerUserId} {
      allow read: if true;
      allow write: if (isSignedIn() && request.auth.uid == followerUserId) || isAdmin();
    }

    match /user_following/{followerUserId}/following/{followedUserId} {
      allow read: if true;
      allow write: if (isSignedIn() && request.auth.uid == followerUserId) || isAdmin();
    }
  }
}