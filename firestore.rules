rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Global Read Rule (Temporary for Debugging)
    // ------------------------------------------------------------------------
    /**
     * @description TEMPORARY: Allows any read operation on any document.
     * This is a temporary, wide-open rule to diagnose a persistent permissions issue.
     * THIS IS NOT SECURE FOR PRODUCTION. It will be replaced with specific,
     * secure rules once the feed functionality is confirmed to be working.
     */
    match /{document=**} {
      allow read: if true;
    }

    // ------------------------------------------------------------------------
    // Helper Functions (For Write Rules)
    // ------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingDoc() {
      return resource != null;
    }

    function isOwnerOfExistingDoc(userId) {
      return isOwner(userId) && isExistingDoc();
    }
    
    // ------------------------------------------------------------------------
    // User Profile & Content Rules - SPECIFIC WRITE ACCESS
    // ------------------------------------------------------------------------
    match /users/{userId} {
      // Read access is handled by the global rule above.
      // Write access is restricted.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwnerOfExistingDoc(userId);
      allow delete: if isOwnerOfExistingDoc(userId);

      match /posts/{postId} { 
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        // Allow owner to update their own post, OR allow any signed in user to increment the view count.
        allow update: if (isOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId) ||
                       (isSignedIn() &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']));
        allow delete: if isOwnerOfExistingDoc(resource.data.userId);

        match /comments/{commentId} {
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.postId == postId;
          allow update: if isOwnerOfExistingDoc(resource.data.userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isExistingDoc() && (isOwner(resource.data.userId) || isOwner(userId)); // resource.data.userId is comment owner, userId is post owner
        }

        match /likes/{likeId} {
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.postId == postId;
          allow update: if false;
          allow delete: if isOwnerOfExistingDoc(resource.data.userId);
        }
      }

      match /stories/{storyId} { 
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isOwnerOfExistingDoc(resource.data.userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isOwnerOfExistingDoc(resource.data.userId);
      }
    }

    // ------------------------------------------------------------------------
    // Follow Relationship Rules
    // ------------------------------------------------------------------------
    match /user_followers/{followedUserId}/followers/{followerUserId} {
      // read is handled by global rule
      // Allow write if the user performing the action is the follower.
      allow write: if request.auth.uid == followerUserId;
    }

    match /user_following/{followerUserId}/following/{followedUserId} {
      // read is handled by global rule
      // Allow write if the user performing the action is the follower.
      allow write: if request.auth.uid == followerUserId;
    }

    // ------------------------------------------------------------------------
    // Denormalized Feed Rules (Write-Only)
    // ------------------------------------------------------------------------
    match /user_feeds/{feedViewerId}/feed_posts/{feedPostId} {
      // read is handled by global rule
      allow write: if false; // No client-side writes
    }

    match /user_story_feeds/{storyFeedViewerId}/feed_stories/{feedStoryId} {
      // read is handled by global rule
      allow write: if false; // No client-side writes
    }
  }
}
