rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function for admin access
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'asnap5319@gmail.com';
    }

    match /users/{userId} {
      allow read: if true;
      // Allow creation during signup, update/delete by owner or admin
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isOwner(userId) || isAdmin();
      
      match /posts/{postId} {
        allow read: if true;
        // Only owner can create posts for themselves
        allow create: if isOwner(userId);
        // Owner or admin can update/delete
        allow update, delete: if isOwner(userId) || isAdmin();
        
        match /likes/{likeId} {
          allow read: if true;
          allow write: if isAuthenticated();
        }
        
        match /comments/{commentId} {
          allow read: if true;
          allow create: if isAuthenticated();
          allow update, delete: if isOwner(userId) || isAdmin();
          
          match /likes/{likeId} {
            allow read: if true;
            allow write: if isAuthenticated();
          }
        }
      }
      
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if isAuthenticated();
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }

    // Global collection group access for the feed
    match /{path=**}/posts/{postId} {
      allow read: if true;
    }

    // Chat system rules - strictly for participants
    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow write: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId;
        allow delete: if isAuthenticated() && (request.auth.uid == resource.data.senderId || isAdmin());
      }
    }

    // Follow system rules
    match /user_followers/{followedUserId}/followers/{followerUserId} {
      allow read: if true;
      allow write: if isOwner(followerUserId);
    }
    match /user_following/{followerUserId}/following/{followedUserId} {
      allow read: if true;
      allow write: if isOwner(followerUserId);
    }

    // Catch-all for any other collections - restricted to Admin
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}